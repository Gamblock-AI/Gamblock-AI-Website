# Gamblock-AI Website — Environment Variables
#
# NEXT_PUBLIC_* vars are inlined at build time by Next.js and are PUBLIC
# (visible to the browser). Never put secrets in a NEXT_PUBLIC_* var.

# Backend API base URL (no trailing slash). Read via lib/config.ts. Local
# development may use HTTP; production deployments should use HTTPS.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public OAuth web client ID. Must match backend GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
