# Gamblock-AI Website — Environment Variables
#
# NEXT_PUBLIC_* vars are inlined at build time by Next.js and are PUBLIC
# (visible to the browser). Never put secrets in a NEXT_PUBLIC_* var.

# Backend API base URL (no trailing slash). Read via lib/config.ts. Local
# development may use HTTP; production deployments should use HTTPS.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public OAuth web client ID. Must match backend GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Public HTTPS origins that may be loaded only after a student accepts an
# external education-media gate. Keep aligned with backend MEDIA_EMBED_HOSTS.
NEXT_PUBLIC_EDUCATION_EMBED_ORIGINS=https://www.youtube-nocookie.com,https://player.vimeo.com,https://who.int,https://www.who.int,https://ppatk.go.id,https://www.ppatk.go.id,https://ojk.go.id,https://www.ojk.go.id,https://komdigi.go.id,https://www.komdigi.go.id,https://kemkes.go.id,https://www.kemkes.go.id
